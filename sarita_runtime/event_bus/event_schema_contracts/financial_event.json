{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Financial Transaction Event",
  "type": "object",
  "properties": {
    "trace_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "event_type": { "enum": ["TRANSACTION_CREATED", "TRANSACTION_SETTLED", "TRANSACTION_FAILED"] },
    "payload": {
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "source_wallet": { "type": "string", "format": "uuid" },
        "target_wallet": { "type": "string", "format": "uuid" }
      },
      "required": ["amount", "currency", "source_wallet", "target_wallet"]
    },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "required": ["trace_id", "tenant_id", "event_type", "payload", "timestamp"]
}
