{
  "name": "@sarita/desktop",
  "version": "1.0.0",
  "description": "SARITA Desktop Application (Electron + React)",
  "main": "main/main.js",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "start": "npm run build && electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "travel.sarita.desktop",
    "productName": "SARITA POS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-renderer/**/*",
      "main/**/*",
      "preload/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sarita-platform",
        "repo": "sarita-desktop"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.0",
    "lucide-react": "^0.344.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1",
    "sqlite3": "^5.1.7",
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.0",
    "@sarita/shared-sdk": "file:../../sarita-platform/shared-sdk"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "@types/sqlite3": "^3.1.11",
    "typescript": "^5.0.0",
    "vite": "^5.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19"
  },
  "private": true
}
